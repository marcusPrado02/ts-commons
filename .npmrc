# Route @marcusprado02 scoped packages to GitHub Packages registry
@marcusprado02:registry=https://npm.pkg.github.com

# Auth token for GitHub Packages (set NODE_AUTH_TOKEN in CI or ~/.npmrc locally)
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

# Prevent accidental publish of the private workspace root
# Individual packages each have publishConfig.access=public
