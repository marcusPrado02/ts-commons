{
  "name": "@marcusprado02/data-pipeline",
  "version": "0.2.0",
  "description": "ETL framework, stream/batch processing, data validation and DLQ for @marcusprado02/ts-commons",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "etl",
    "pipeline",
    "stream",
    "batch",
    "data-pipeline",
    "dlq",
    "data-validation"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
