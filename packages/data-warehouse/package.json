{
  "name": "@marcusprado02/data-warehouse",
  "version": "0.1.0",
  "description": "Data warehouse integration: Snowflake, BigQuery, Redshift, sync strategies and schema evolution for @marcusprado02/ts-commons",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "data-warehouse",
    "snowflake",
    "bigquery",
    "redshift",
    "schema-evolution",
    "data-sync"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
