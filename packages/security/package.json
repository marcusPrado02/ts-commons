{
  "name": "@marcusprado02/security",
  "version": "0.2.0",
  "description": "Security: AuthN/AuthZ, Crypto, PII, Audit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@marcusprado02/kernel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "security",
    "authentication",
    "authorization",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusPrado02/ts-commons.git"
  },
  "bugs": "https://github.com/marcusPrado02/ts-commons/issues",
  "homepage": "https://github.com/marcusPrado02/ts-commons/tree/main/packages/security#readme",
  "files": [
    "dist",
    "src",
    "README.md"
  ]
