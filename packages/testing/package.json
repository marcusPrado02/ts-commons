{
  "name": "@marcusprado02/testing",
  "version": "0.2.0",
  "description": "Testing utilities: Builders, Fakes, Test harnesses",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@marcusprado02/kernel": "workspace:*",
    "@marcusprado02/application": "workspace:*",
    "@marcusprado02/messaging": "workspace:*",
    "@marcusprado02/outbox": "workspace:*"
  },
  "keywords": [
    "testing",
    "test-builders",
    "fakes",
    "test-harness"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusPrado02/ts-commons.git"
  },
  "bugs": "https://github.com/marcusPrado02/ts-commons/issues",
  "homepage": "https://github.com/marcusPrado02/ts-commons/tree/main/packages/testing#readme",
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
