{
  "name": "@marcusprado02/web-fastify",
  "version": "0.2.0",
  "description": "Fastify adapter for ts-commons platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@marcusprado02/kernel": "workspace:*",
    "@marcusprado02/application": "workspace:*",
    "@marcusprado02/errors": "workspace:*",
    "@marcusprado02/observability": "workspace:*",
    "@marcusprado02/web": "workspace:*",
    "fastify": "^4.26.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "vitest": "^4.0.18",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusPrado02/ts-commons.git"
  },
  "bugs": "https://github.com/marcusPrado02/ts-commons/issues",
  "homepage": "https://github.com/marcusPrado02/ts-commons/tree/main/packages/web-fastify#readme",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "fastify": "^4.0.0"
  }
}
