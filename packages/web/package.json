{
  "name": "@marcusprado02/web",
  "version": "0.2.0",
  "description": "Web adapters: HTTP server abstractions and middlewares",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@marcusprado02/kernel": "workspace:*",
    "@marcusprado02/errors": "workspace:*",
    "@marcusprado02/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "web",
    "http",
    "fastify",
    "middleware",
    "hateoas",
    "hal",
    "json-api"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcusPrado02/ts-commons.git"
  },
  "bugs": "https://github.com/marcusPrado02/ts-commons/issues",
  "homepage": "https://github.com/marcusPrado02/ts-commons/tree/main/packages/web#readme",
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
